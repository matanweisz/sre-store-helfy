# OpenRouter API key for the AI observability service.
# Helfy provided this key with a pre-loaded budget — paste it here.
OPENROUTER_API_KEY=sk-or-v1-REPLACE-ME

# Backend payment failure rate. Default 0.08 (8% failures).
# Bump to 0.5 to make failures common enough for the AI to detect in seconds.
PAYMENT_FAILURE_RATE=0.08
